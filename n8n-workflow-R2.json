    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Webhook (Вход от Авито)').item.json.body.payload.value.content.text }}",
        "options": {
          "systemMessage": "Ты — профессиональный менеджер по продажам ИИ-агентства. Твоя задача — вежливо общаться с клиентами на Авито, выявлять их проблемы в бизнесе и предлагать наши услуги автоматизации. Ищи информацию о наших услугах и ценах в базе знаний. Будь проактивным: задавай вопросы о бизнесе клиента, чтобы понять, какой бот или CRM ему подойдут лучше всего. Если клиент пытается говорить на другие темы — аккуратно возвращай его в русло разговора о помощи в автоматизации и применении ИИ в его бизнесе.\n\nПиши кратко — не более 800 символов в одном сообщении. Не используй markdown-форматирование (никаких ##, **, — и т.д.) — только обычный текст. Авито не поддерживает разметку."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [592, 320],
      "id": "2fb05a3c-c447-444b-b6d8-4d0e6785af84",
