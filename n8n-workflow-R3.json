    {
      "parameters": {
        "jsCode": "const text = $input.item.json.output || '';\nconst clean = text\n  .replace(/[#*_~`]/g, '')\n  .replace(/[«»]/g, '\"')\n  .replace(/–|—/g, '-')\n  .replace(/₽/g, 'руб.')\n  .replace(/\\n{2,}/g, '\\n')\n  .trim();\n\nconst LIMIT = 800;\n\nif (clean.length <= LIMIT) {\n  return [{ json: { ...$input.item.json, output: clean } }];\n}\n\nconst truncated = clean.slice(0, LIMIT);\nconst lastSentenceEnd = Math.max(\n  truncated.lastIndexOf('. '),\n  truncated.lastIndexOf('! '),\n  truncated.lastIndexOf('? ')\n);\n\nconst result = lastSentenceEnd > LIMIT * 0.6\n  ? truncated.slice(0, lastSentenceEnd + 1)\n  : truncated.slice(0, LIMIT).trimEnd() + '...';\n\nreturn [{ json: { ...$input.item.json, output: result } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [912, 320],
      "id": "0e64f1fe-7726-4a95-99fd-a143c267a3b2",
      "name": "Обрезать ответ"
    },
    {
      "parameters": {
        "jsCode": "const botReply = $input.item.json.output || '';\nconst clientMessage = $('Webhook (Вход от Авито)').item.json.body.payload.value.content.text || '';\n\nconst hotSignals = [\n  'интересно', 'интерес', 'хочу', 'давайте', 'расскажите подробнее',\n  'сколько стоит', 'как начать', 'готов', 'попробуем', 'свяжитесь',\n  'когда можно', 'договоримся', 'обсудим', 'да', 'окей', 'ок'\n];\n\nconst text = clientMessage.toLowerCase();\nconst isHot = hotSignals.some(signal => text.includes(signal));\n\nreturn [{ json: { ...$input.item.json, isHot } }];"
      },
